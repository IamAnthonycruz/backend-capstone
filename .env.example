# Copy to .env and adjust as needed. Consumed by docker-compose.yml and,
# when exported, by the Spring Boot app (all map to application.yml keys).

# Active Spring profile
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# PostgreSQL
DB_NAME=readshelf
DB_USERNAME=readshelf
DB_PASSWORD=readshelf
DB_PORT=5432
DB_URL=jdbc:postgresql://localhost:5432/readshelf

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
RABBITMQ_USERNAME=readshelf
RABBITMQ_PASSWORD=readshelf

# Elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# MinIO (object storage)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=readshelf
MINIO_SECRET_KEY=readshelf-secret
MINIO_BUCKET=book-covers

# Mail (MailHog in dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_UI_PORT=8025
MAIL_USERNAME=
MAIL_PASSWORD=

# JWT (use a strong, 256-bit+ secret in production)
JWT_SECRET=change-me-in-prod-this-must-be-at-least-256-bits-long
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P7D
